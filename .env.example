# Beispiel Konfiguration über .env
# Dieses File dient als Vorlage für die lokale .env Datei
# Werte hier sind Platzhalter – ersetze sie durch reale Angaben aus deinem
# Active‑Directory/Netzwerk.

# SMB aktiviert = true/false (die Anwendung verwendet dann den Netzwerklaufwerk-Pfad)
SMB_ENABLED=true

# FQDN oder IP des Windows-Dateiserver (DNS-Name z. B. `adfileserver.corp.local`)
SMB_SERVER=adfileserver.corp.local

# Name der Freigabe auf dem Server (z. B. "PDFs" oder "SharedDocs").
# Einige Freigaben sind versteckt und enden auf '$' (z. B. "Share$").
# Der resultierende UNC-Pfad kann dann entweder so aussehen:
#   \\fileserver.domain.local\Share$\pfad\zum\pdf\ablage\ordner   (versteckte Freigabe)
# oder
#   \\fileserver.domain.local\Share\pfad\zum\pdf\ablage\ordner    (normale Freigabe)
SMB_SHARE=Share$

# Optionaler Unterordner in der Freigabe (leer lassen, wenn direkt im Share).
#   SMB_FOLDER=pfad/zum/pdf/ablage/ordner
SMB_FOLDER=pfad/zum/pdf/ablage/ordner

# Anmeldeinformationen – normalerweise ein Domänenkonto
SMB_USERNAME=svc_formflow@corp.local
SMB_PASSWORD=BeispielPasswort
